# TWO Bank ATM — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.eggs/

# Virtual Environment
.venv/
venv/
env/

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Type Checking
.mypy_cache/
.ruff_cache/

# Secrets — NEVER commit these
.env
*.pem
*.key

# Database (local dev data)
data/*.db
data/*.sqlite

# Logs
logs/*.log

# VS Code user-specific (workspace settings ARE committed)
.history/

# OS
.DS_Store
Thumbs.db

# Qodo / AI tools
.qodo/
